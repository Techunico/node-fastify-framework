{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "./dist",
    "baseUrl": "./src",
    "types": ["node", "jest"],
    "paths": {
      "@/*": ["*"]
    },
    "ignoreDeprecations": "6.0",
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
