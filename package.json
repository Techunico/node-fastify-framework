{
  "name": "nodejs_framework",
  "version": "1.0.0",
  "main": "server.ts",
  "bin": {
    "create-techunico-app": "index.js"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts",
    "typecheck": "tsc --noEmit",
    "make:module": "ts-node -r tsconfig-paths/register src/scripts/make-module.ts",
    "test": "jest",
    "build:template": "ts-node src/scripts/build-template.ts",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "migrate:pg": "prisma migrate dev --schema=prisma/schema.postgresql.prisma",
    "migrate:sqlite": "prisma migrate dev --schema=prisma/schema.sqlite.prisma",
    "generate:pg": "prisma generate --schema=prisma/schema.postgresql.prisma",
    "generate:sqlite": "prisma generate --schema=prisma/schema.sqlite.prisma"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.74.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "tsconfig-paths": "^4.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "jest": "^30.3.0",
    "prisma": "^7.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
